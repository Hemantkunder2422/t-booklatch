generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  userType        UserType
  role            Role
  venueId         String?
  vendorId        String?
  isActive        Boolean        @default(true)
  isVerified      Boolean        @default(false)
  createdById     String?
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  metaData        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  isOnBoarded     Boolean?
  profileImage    String?
  invites         Invite[]
  refreshTokens   RefreshToken[]
  createdBookings Booking[]      @relation("BookingCreatedBy")
  createdBy       User?          @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdByUsers  User[]         @relation("UserCreatedBy")
  vendor          Vendor?        @relation("VendorUsers", fields: [vendorId], references: [id])
  venue           Venue?         @relation("VenueUsers", fields: [venueId], references: [id])
  createdVendors  Vendor[]       @relation("VendorCreatedBy")
  createdVenues   Venue[]        @relation("VenueCreatedBy")
  ownedVenues     Venue[]        @relation("VenueOwner")

  @@index([email])
  @@index([role])
  @@index([userType])
  @@index([venueId])
  @@index([vendorId])
}

model VenueImageGallery {
  id           String       @id @default(uuid())
  venueId      String
  venueSpaceId String?
  imageKey     String
  displayOrder Int          @default(0)
  venue        Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueSpace   VenueSpaces? @relation(fields: [venueSpaceId], references: [id], onDelete: Cascade)
  isPrimary    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([venueId, venueSpaceId, displayOrder])
  @@index([venueId])
  @@index([venueSpaceId])
}

model Invite {
  id          String   @id @default(uuid())
  email       String
  role        Role
  userType    UserType
  invitedById String
  token       String   @unique
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  vendorId    String?
  venueId     String?
  invitedBy   User     @relation(fields: [invitedById], references: [id])
}

model Venue {
  id                  String              @id @default(uuid())
  name                String
  description         String?
  address             String?
  city                String?
  state               String?
  country             String?
  pincode             String?
  phone               String?
  email               String?
  website             String?
  capacity            Int?
  priceRange          String?
  openingTime         String
  closingTime         String
  createdById         String
  isActive            Boolean             @default(true)
  isVerified          Boolean             @default(false)
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  ownerId             String
  users               User[]              @relation("VenueUsers")
  venueSpaces         VenueSpaces[]
  bookings            Booking[]
  bookingEnquiries    BookingEnquiry[]
  createdBy           User                @relation("VenueCreatedBy", fields: [createdById], references: [id])
  owner               User                @relation("VenueOwner", fields: [ownerId], references: [id])
  latitude            Decimal?            @db.Decimal(9, 6)
  longitude           Decimal?            @db.Decimal(9, 6)
  venueImageGalleries VenueImageGallery[]

  @@index([city])
  @@index([name])
  @@index([createdById])
  @@index([latitude, longitude])
}

model Vendor {
  id          String     @id @default(uuid())
  name        String
  description String?
  type        VendorType
  phone       String?
  email       String?
  website     String?
  city        String?
  state       String?
  country     String?
  createdById String
  isActive    Boolean    @default(true)
  isVerified  Boolean    @default(false)
  metaData    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lat         Float?
  long        Float?
  users       User[]     @relation("VendorUsers")
  createdBy   User       @relation("VendorCreatedBy", fields: [createdById], references: [id])

  @@index([type])
  @@index([city])
}

model VenueSpaces {
  id                  String               @id @default(uuid())
  venueId             String
  name                String
  description         String
  morningSlotEnabled  Boolean              @default(true)
  eveningSlotEnabled  Boolean              @default(true)
  fullDaySlotEnabled  Boolean              @default(true)
  pax                 Int
  venue               Venue                @relation(fields: [venueId], references: [id])
  calendarEntries     VenueSpaceCalendar[]
  bookingEnquiry      BookingEnquiry[]
  bookings            Booking[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  venueImageGalleries VenueImageGallery[]

  @@index([venueId, name])
}

model Booking {
  id              String               @id @default(uuid())
  venueId         String
  venueSpaceId    String
  customerName    String
  customerPhone   String
  customerEmail   String
  eventName       String
  eventType       EventType
  bookingDate     DateTime             @db.Date
  startTime       DateTime
  endTime         DateTime
  bookingStatus   BookingStatus        @default(PENDING)
  source          BookingSource        @default(INTERNAL)
  pax             Int
  notes           String?
  createdById     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  venue           Venue                @relation(fields: [venueId], references: [id])
  venueSpace      VenueSpaces          @relation(fields: [venueSpaceId], references: [id])
  createdBy       User?                @relation("BookingCreatedBy", fields: [createdById], references: [id])
  calendarEntries VenueSpaceCalendar[]
  payments        Payment[]
  invoice         Invoice?
  receipts        Receipt[]

  @@index([venueSpaceId, bookingDate])
  @@index([createdById])
}

model VenueSpaceCalendar {
  id           String         @id @default(uuid())
  venueSpaceId String
  date         DateTime       @db.Date
  slot         BookingSlot
  status       CalendarStatus
  notes        String?
  bookingId    String?
  booking      Booking?       @relation(fields: [bookingId], references: [id])
  venueSpace   VenueSpaces    @relation(fields: [venueSpaceId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([venueSpaceId, date])
  @@index([bookingId])
}

model BookingEnquiry {
  id            String        @id @default(uuid())
  venueId       String
  venueSpaceId  String
  customerName  String
  customerPhone String
  customerEmail String?
  eventName     String?
  eventType     EventType?
  bookingDate   DateTime      @db.Date
  slot          BookingSlot
  status        EnquiryStatus @default(NEW)
  source        BookingSource @default(INTERNAL)
  pax           Int?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  venue         Venue         @relation(fields: [venueId], references: [id])
  venueSpace    VenueSpaces   @relation(fields: [venueSpaceId], references: [id])

  @@index([venueId])
  @@index([bookingDate])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String
  userAgent String?
  ipAddress String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Payment {
  id               String        @id @default(uuid())
  bookingId        String
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("INR")
  paymentMethod    PaymentType
  paymentStatus    PaymentStatus @default(PENDING)
  transactionID    String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  paidAt           DateTime
  failureReason    String?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  booking          Booking       @relation(fields: [bookingId], references: [id])
  invoice          Invoice?
  receipts         Receipt[]

  @@index([bookingId])
  @@index([paymentStatus])
}

model Invoice {
  id               String            @id @default(uuid())
  bookingId        String            @unique
  paymentId        String            @unique
  invoiceNumber    String            @unique
  subTotal         Decimal           @db.Decimal(10, 2)
  taxAmount        Decimal           @db.Decimal(10, 2)
  gstPercentage    Decimal?          @db.Decimal(5, 2)
  cgstAmount       Decimal?          @db.Decimal(10, 2)
  sgstAmount       Decimal?          @db.Decimal(10, 2)
  igstAmount       Decimal?          @db.Decimal(10, 2)
  issuedAt         DateTime
  pdfUrl           String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bookings         Booking           @relation(fields: [bookingId], references: [id])
  payments         Payment           @relation(fields: [paymentId], references: [id])
  receipts         Receipt[]
  invoiceLineItems BillingLineItem[]

  @@index([bookingId])
  @@index([paymentId])
}

model Receipt {
  id               String            @id @default(uuid())
  receiptNumber    String            @unique
  bookingId        String
  paymentId        String
  invoiceId        String?
  amount           Decimal           @db.Decimal(10, 2)
  paymentMethod    PaymentType
  pdfUrl           String?
  issuedAt         DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  booking          Booking           @relation(fields: [bookingId], references: [id])
  payment          Payment           @relation(fields: [paymentId], references: [id])
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  invoiceLineItems BillingLineItem[]
}

model BillingLineItem {
  id            String                  @id @default(uuid())
  invoiceId     String?
  receiptId     String?
  description   String
  category      InvoiceLineItemCategory
  quantity      Int
  unitPrice     Decimal                 @db.Decimal(10, 2)
  taxPercentage Decimal                 @db.Decimal(10, 2)
  taxAmount     Decimal                 @db.Decimal(10, 2)
  discount      Decimal                 @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal                 @db.Decimal(10, 2)
  invoice       Invoice?                @relation(fields: [invoiceId], references: [id])
  receipt       Receipt?                @relation(fields: [receiptId], references: [id])

  @@index([invoiceId])
  @@index([receiptId])
}

model WebsiteLead {
  id      String  @id @default(uuid())
  name    String
  email   String  @unique
  phone   String
  message String?
}

enum UserType {
  VENDOR
  VENUE
  ADMIN
}

enum InvoiceLineItemCategory {
  VENUE_RENT
  CATERING
  DECORATION
  PARKING
  OTHERS
}

enum Role {
  VENDOR_ADMIN
  VENDOR_STAFF
  VENUE_ADMIN
  VENUE_STAFF
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

enum VendorType {
  FOOD
  DECOR
  PHOTOGRAPHY
  MUSIC
}

enum EventType {
  WEDDING
  BIRTHDAY
  OTHERS
  RECEPTION
  CORPORATE
}

enum BookingStatus {
  PENDING // Booking created, awaiting action or payment
  BOOKING_IN_PROGRESS // Staff/admin is actively creating the booking
  LOCKED // Slot reserved for a customer for a limited period (e.g. 24 hours)
  CONFIRMED // Payment successful, booking confirmed
  CANCELLED // Booking cancelled or abandoned
  COMPLETED // Event has concluded
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentType {
  CASH
  CARD
  UPI
  NET_BANKING
}

enum CalendarStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  MAINTENANCE
}

enum BookingSlot {
  MORNING
  EVENING
  FULL_DAY
}

enum BookingSource {
  INTERNAL
  PHONE
  WHATSAPP
  CUSTOMER_APP
}

enum EnquiryStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CONVERTED
  CLOSED
}
