generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  password       String
  userType       UserType
  role           Role
  venueId        String?
  vendorId       String?
  isActive       Boolean        @default(true)
  isVerified     Boolean        @default(false)
  createdById    String?
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  metaData       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  isOnBoarded    Boolean?
  invites        Invite[]
  refreshTokens  RefreshToken[]
  createdBy      User?          @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdByUsers User[]         @relation("UserCreatedBy")
  vendor         Vendor?        @relation("VendorUsers", fields: [vendorId], references: [id])
  venue          Venue?         @relation("VenueUsers", fields: [venueId], references: [id])
  createdVendors Vendor[]       @relation("VendorCreatedBy")
  createdVenues  Venue[]        @relation("VenueCreatedBy")
  ownedVenues    Venue[]        @relation("VenueOwner")

  @@index([email])
  @@index([role])
  @@index([userType])
  @@index([venueId])
  @@index([vendorId])
}

model Invite {
  id          String   @id @default(uuid())
  email       String
  role        Role
  userType    UserType
  invitedById String
  token       String   @unique
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  vendorId    String?
  venueId     String?
  invitedBy   User     @relation(fields: [invitedById], references: [id])
}

model Venue {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  city        String?
  state       String?
  country     String?
  pincode     String?
  phone       String?
  email       String?
  website     String?
  capacity    Int?
  priceRange  String?
  createdById String
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  gallery String[]
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  users       User[]   @relation("VenueUsers")
  venueSpaces VenueSpaces[]
  bookings Booking[]
  createdBy   User     @relation("VenueCreatedBy", fields: [createdById], references: [id])
  owner       User     @relation("VenueOwner", fields: [ownerId], references: [id])

  @@index([city])
  @@index([name])
  @@index([createdById])
}

model Vendor {
  id          String     @id @default(uuid())
  name        String
  description String?
  type        VendorType
  phone       String?
  email        String?
  website     String?
  city        String?
  state       String?
  country     String?
  createdById String
  isActive    Boolean    @default(true)
  isVerified  Boolean    @default(false)
  metaData    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lat         Float?
  long        Float?
  users       User[]     @relation("VendorUsers")
  createdBy   User       @relation("VendorCreatedBy", fields: [createdById], references: [id])

  @@index([type])
  @@index([city])
}

model VenueSpaces {
  id String @id @default(uuid())
  venueId String
  name String
  description String
  pax Int
  gallery String[]
  venue Venue @relation(fields: [venueId], references: [id])
  calendarEntries VenueSpaceCalendar[]
  bookings Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId,name])
}

model Booking {
  id String @id @default(uuid())
  venueId String
  venueSpaceId String
  customerName String
  customerPhone String
  customerEmail String
  eventName String
  eventType EventType
  startDate DateTime
  endDate DateTime
  pax Int
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  venue Venue @relation(fields: [venueId], references: [id])
  venueSpace VenueSpaces @relation(fields: [venueSpaceId],references: [id])

  @@index([venueSpaceId])
  @@index([startDate])
  @@index([endDate])
}

model VenueSpaceCalendar {
  id String @id @default(uuid())
  venueSpaceId String
  date DateTime @db.Date
  status CalendarStatus
  notes String?
  bookingId String?
  venueSpace VenueSpaces @relation(fields: [venueSpaceId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venueSpaceId,date])
  @@index([venueSpaceId,date])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String
  userAgent String?
  ipAddress String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserType {
  VENDOR
  VENUE
  ADMIN
}

enum Role {
  VENDOR_ADMIN
  VENDOR_STAFF
  VENUE_ADMIN
  VENUE_STAFF
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

enum VendorType {
  FOOD
  DECOR
  PHOTOGRAPHY
  MUSIC
}

enum EventType {
  WEDDING
  BIRTHDAY
  OTHERS
  RECEPTION
  CORPORATE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum CalendarStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  MAINTENANCE
}